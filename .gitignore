.har-filterrc
.har-filterrc.json

# Temporary test outputs
/tmp/
/temp/
/test/output/
/test/fixtures/output/

# Performance profiling
*.prof
*.trace
flamegraph.html

# Coverage reports (if added in future)
coverage/
.nyc_output/
