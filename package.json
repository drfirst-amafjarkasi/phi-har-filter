{
  "name": "har-filter",
  "version": "1.0.0",
  "description": "Parse and filter HAR files with HIPAA-oriented privacy redaction for DrFirst domains",
  "type": "module",
  "bin": {
    "har-filter": "./bin/har-filter.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": "./src/cli.js",
    "./domains": "./src/domains.js",
    "./match": "./src/match.js",
    "./redact": "./src/redact.js",
    "./filter": "./src/filter.js",
    "./summarize": "./src/summarize.js",
    "./output": "./src/output.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/har-filter.git"
  },
  "keywords": [
    "har",
    "http-archive",
    "privacy",
    "redaction",
    "hipaa",
    "drfirst",
    "cli",
    "node",
    "phi",
    "filtering",
    "network-analysis",
    "security"
  ],
  "author": "Claude Code <noreply@anthropic.com>",
  "license": "MIT",
  "homepage": "https://github.com/YOUR_ORG/har-filter#readme",
  "bugs": {
    "url": "https://github.com/YOUR_ORG/har-filter/issues"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "stream-chain": "^2.2.5",
    "stream-json": "^1.9.1"
  }
}
